{
  "name": "wallet-tree",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "frontend:dev": "pnpm --filter frontend dev",
    "backend:dev": "pnpm --filter backend start:dev",
    "db:generate": "pnpm --filter @wallet-tree/database prisma:generate",
    "db:migrate": "pnpm --filter @wallet-tree/database prisma:migrate",
    "db:deploy": "pnpm --filter @wallet-tree/database prisma:deploy",
    "db:seed": "pnpm --filter @wallet-tree/database db:seed",
    "db:studio": "pnpm --filter @wallet-tree/database prisma:studio",
    "bootstrap": "pnpm install && pnpm db:generate && pnpm build && pnpm db:migrate && pnpm db:seed"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
