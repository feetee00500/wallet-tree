{
  "name": "wallet-tree",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r --if-present test",
    "frontend:dev": "pnpm --filter frontend dev",
    "backend:dev": "pnpm --filter backend start:dev",
    "db:indexes": "pnpm --filter @wallet-tree/database db:indexes",
    "db:seed": "pnpm --filter @wallet-tree/database db:seed",
    "bootstrap": "pnpm install && pnpm build && pnpm db:indexes && pnpm db:seed"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
