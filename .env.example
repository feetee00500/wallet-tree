# MongoDB Atlas
MONGODB_URI="mongodb+srv://username:password@cluster.example.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB_NAME="wallet_tree"

# Backend
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
JWT_SECRET=replace-with-at-least-32-random-characters
LINE_STATE_SECRET=replace-with-another-32-character-random-secret
CRON_SECRET=replace-with-at-least-32-random-characters

# LINE Login (regular users only)
LINE_LOGIN_CHANNEL_ID=replace-with-login-channel-id
LINE_LOGIN_CHANNEL_SECRET=replace-with-login-channel-secret
LINE_LOGIN_CALLBACK_URL=http://localhost:3000/api/auth/line/callback

# LINE Messaging API
LINE_CHANNEL_SECRET=replace-with-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=replace-with-channel-access-token
# Optional: without this, LINE transactions use the fallback category
ANTHROPIC_API_KEY=replace-with-anthropic-api-key

# Admin account seeded into MongoDB Atlas (local development/bootstrap)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-unique-password-of-at-least-12-characters
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=15

# Frontend (Vite reads VITE_* at build time)
VITE_API_BASE_URL=http://localhost:3000
