# Frontend public variables (safe to expose to browser bundles)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000
NEXT_PUBLIC_LIFF_ID=replace-with-liff-id

# Backend and MongoDB
MONGODB_URI=mongodb://username:password@localhost:27017/wallet-tree
MONGODB_DB_NAME=wallet-tree

# LINE Messaging API (backend only)
LINE_CHANNEL_ID=replace-with-channel-id
LINE_CHANNEL_SECRET=replace-with-channel-secret
LINE_CHANNEL_ACCESS_TOKEN=replace-with-channel-access-token

# LINE Login (backend only)
LINE_LOGIN_CHANNEL_ID=replace-with-login-channel-id
LINE_LOGIN_CHANNEL_SECRET=replace-with-login-channel-secret
LINE_LOGIN_CALLBACK_URL=http://localhost:3000/api/auth/line/callback

# Application origins
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# Security and sessions (backend only; use unique values of at least 32 characters)
SESSION_SECRET=replace-with-at-least-32-random-characters
CSRF_SECRET=replace-with-at-least-32-random-characters

# Local maintenance administrator (disabled by default)
ENABLE_LOCAL_ADMIN_LOGIN=false
ADMIN_LOGIN_MAX_ATTEMPTS=5
ADMIN_LOGIN_LOCKOUT_MINUTES=15
